model TeachingAssignment {
    id String @id @default(uuid())

    teacherId String
    teacher   Teacher @relation(fields: [teacherId], references: [id])

    subjectAssignmentId String
    subjectAssignment   SubjectAssignment @relation(fields: [subjectAssignmentId], references: [id])

    createdAt         DateTime         @default(now())
    updatedAt DateTime @default(now()) @updatedAt
    isActive          Boolean          @default(true)
    academicSession   AcademicSession? @relation(fields: [academicSessionId], references: [id])
    academicSessionId String?

    @@unique([teacherId, subjectAssignmentId])
}

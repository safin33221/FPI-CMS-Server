model Department {
  id String @id @unique @default(uuid())

  name String
  code String @unique

  students Student[]
  teachers Teacher[]

  headId String?  @unique
  head   Teacher? @relation("DepartmentHead", fields: [headId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  subjects  Subject[]
}

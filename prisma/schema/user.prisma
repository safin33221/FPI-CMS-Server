model User {
    id   String @id @default(uuid())
    name String

    email    String @unique
    password String
    role     Role

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    isVerified Boolean   @default(false)
    isActive   Boolean   @default(true)
    lastLogin  DateTime?

    // Personal Info
    profileImage String?
    gender       Gender?
    dateOfBirth  DateTime?
    phone        String?   @unique

    // Address
    address  String?
    city     String?
    district String?

    // Relations
    student Student?
    teacher Teacher?
}

model Student {
    id     String @id @default(uuid())
    userId String @unique
    user   User   @relation(fields: [userId], references: [id])

    // Unique Data
    roll           String @unique
    registrationNo String @unique

    session String?
    batch   String?
}

model Teacher {
    id String @id @default(uuid())

    userId String @unique
    user   User   @relation(fields: [userId], references: [id])

    // Academic / Professional Info
    designation   String
    qualification String?
    teacherId     String  @unique

    // designation   String
    // qualification String?
    // subjects          Subject[]
    // attendanceSessions AttendanceSession[]

    joiningDate DateTime?

    experienceYears Int?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

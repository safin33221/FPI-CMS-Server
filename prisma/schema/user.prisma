model User {
    id   String  @id @default(uuid())
    name String?

    email    String @unique
    password String
    role     Role

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    isVerified Boolean   @default(false)
    isActive   Boolean   @default(true)
    lastLogin  DateTime?

    profileImage String?

    // Personal Info
    gender      Gender?
    dateOfBirth DateTime?

    
}
